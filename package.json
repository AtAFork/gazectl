{
  "name": "gazectl",
  "version": "0.10.0",
  "description": "Head tracking display focus switcher for macOS",
  "bin": {
    "gazectl": "bin/gazectl"
  },
  "files": [
    "bin/gazectl",
    "bin/gazectl-bin"
  ],
  "scripts": {
    "build:npm-binary": "./scripts/build-npm-binary.sh",
    "prepack": "./scripts/build-npm-binary.sh",
    "sync-version": "./scripts/sync-version.sh",
    "version": "./scripts/sync-version.sh",
    "build": "npm run sync-version && swift build -c release"
  },
  "keywords": [
    "head-tracking",
    "display",
    "monitor",
    "focus",
    "accessibility",
    "macos",
    "webcam",
    "swift",
    "vision"
  ],
  "os": [
    "darwin"
  ],
  "author": "Sahaj Jain",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jnsahaj/gazectl.git"
  },
  "homepage": "https://github.com/jnsahaj/gazectl"
}
